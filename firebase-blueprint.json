{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "name": { "type": "string", "description": "Full name of the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback submitted by users about the juices.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["name", "email", "message", "rating", "createdAt"]
    },
    "Subscription": {
      "title": "Juice Subscription",
      "description": "Subscription details for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "cancelled"] },
        "startDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planName", "status", "startDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback submissions."
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User subscription records."
    }
  }
}
